# Vercel Postgres（在 Vercel Dashboard 绑定 Storage 后自动注入）
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# 本地开发时可手动填写 Neon / Supabase 等 Postgres 连接串
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# 管理后台口令（请求头 X-Admin-Token）；客户端切勿打包此值
ADMIN_TOKEN=change-me

# 客户端请求头 X-App-Id 校验（可选，空则跳过）
APP_ID=xunmi
